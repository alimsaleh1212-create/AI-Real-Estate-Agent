# Git
.git
.gitignore

# Secrets — never in image
.env
.env.*

# Python artifacts — rebuilt by uv inside container
__pycache__/
*.py[cod]
.venv/
venv/

# IDE & OS
.idea/
.vscode/
.DS_Store

# Dev-only files — not needed at runtime
tests/
notebooks/
*.md
htmlcov/
.coverage
.pytest_cache/
.mypy_cache/
.pre-commit-config.yaml

# Docker config itself — not needed inside the image
docker-compose*.yml
Dockerfile

# Processed CSV splits not needed at runtime — raw CSV is required by the dashboard
data/processed/

# Dev-only data files
notebooks_temp/
skills/
resources/